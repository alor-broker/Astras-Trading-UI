{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "pnpm",
    "schematicCollections": [
      "angular-eslint"
    ],
    "analytics": false
  },
  "newProjectRoot": "projects",
  "projects": {
    "desktop-terminal": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "less",
          "skipTests": true,
          "changeDetection": "OnPush",
          "viewEncapsulation": "None"
        }
      },
      "root": "projects/desktop-terminal",
      "sourceRoot": "projects/desktop-terminal/src",
      "prefix": "atsd",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/desktop-terminal/src/main.ts",
            "tsConfig": "projects/desktop-terminal/tsconfig.app.json",
            "inlineStyleLanguage": "less",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/desktop-terminal/public"
              },
              {
                "glob": "**/*",
                "input": "./node_modules/@ant-design/icons-angular/src/inline-svg/",
                "output": "/assets/"
              },
              {
                "glob": "**/*",
                "input": "projects/terminal-styling-lib/src/custom_icons",
                "output": "/assets/"
              },
              {
                "glob": "**/*",
                "input": "projects/terminal-styling-lib/src/pwa-icons",
                "output": "/assets/pwa-icons"
              },
              {
                "glob": "**/*",
                "input": "projects/terminal-i18n/i18n",
                "output": "/assets/i18n"
              },
              {
                "glob": "**/*",
                "input": "projects/terminal-core-lib/src/assets",
                "output": "/assets/"
              },
              {
                "glob": "**/*",
                "input": "projects/terminal-widgets-lib/src/assets",
                "output": "/assets/"
              }
            ],
            "styles": [
              {
                "input": "projects/terminal-styling-lib/src/styles/themes/dark-theme.less",
                "bundleName": "dark-theme",
                "inject": false
              },
              {
                "input": "projects/terminal-styling-lib/src/styles/themes/light-theme.less",
                "bundleName": "light-theme",
                "inject": false
              },
              {
                "input": "projects/terminal-styling-lib/src/styles/utils/index.less",
                "bundleName": "utils",
                "inject": true
              },
              "projects/desktop-terminal/src/styles/styles.less"
            ],
            "stylePreprocessorOptions": {
              "includePaths": [
                "projects/terminal-styling-lib/src/styles/mixins"
              ]
            },
            "allowedCommonJsDependencies": [
              "flat",
              "json-patch",
              "gql-query-builder",
              "moment"
            ],
            "serviceWorker": "projects/desktop-terminal/ngsw-config.json"
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "2.5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4.5kb",
                  "maximumError": "9kb"
                }
              ],
              "outputHashing": "all",
              "fileReplacements": [
                {
                  "replace": "projects/desktop-terminal/src/environments/environment.ts",
                  "with": "projects/desktop-terminal/src/environments/environment.prod.ts"
                }
              ]
            },
            "devContour": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "2.5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4.5kb",
                  "maximumError": "9kb"
                }
              ],
              "outputHashing": "all",
              "fileReplacements": [
                {
                  "replace": "projects/desktop-terminal/src/environments/environment.ts",
                  "with": "projects/desktop-terminal/src/environments/environment.dev.ts"
                }
              ]
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "desktop-terminal:build:production"
            },
            "development": {
              "buildTarget": "desktop-terminal:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/desktop-terminal/src/**/*.ts",
              "projects/desktop-terminal/src/**/*.html"
            ]
          }
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "reporters": [
              "default",
              "github-actions"
            ]
          }
        }
      }
    },
