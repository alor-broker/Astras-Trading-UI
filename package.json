{
  "name": "astras-web-terminal",
  "version": "8.0.0",
  "scripts": {
    "ng": "ng",
    "build": "ng build",
    "lint": "ng lint --max-warnings 0",
    "codegen-hyperion": "graphql-codegen --config hyperion-codegen.ts",
    "codegen-news": "graphql-codegen --config news-codegen.ts",
    "start:desktop": "ng serve --project desktop-terminal",
    "start:mobile": "ng serve --project mobile-terminal",
    "start:admin": "ng serve --project admin-terminal --port 4220",
    "build:desktop": "ng build --project desktop-terminal",
    "build:mobile": "ng build --project mobile-terminal",
    "build:admin": "ng build --project admin-terminal",
    "build:all": "ng build --project desktop-terminal && ng build --project mobile-terminal && ng build --project admin-terminal",
    "test": "ng test desktop-terminal --no-watch && ng test mobile-terminal --no-watch && ng test admin-terminal --no-watch && ng test terminal-core-lib --no-watch && ng test terminal-widgets-lib --no-watch",
    "test:desktop": "ng test desktop-terminal",
    "test:mobile": "ng test mobile-terminal",
    "test:admin": "ng test admin-terminal",
    "test:core-lib": "ng test terminal-core-lib",
    "test:widgets-lib": "ng test terminal-widgets-lib",
    "prepare": "husky"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/cdk": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/service-worker": "^21.0.0",
    "@apollo/client": "^4.0.0",
    "@capacitor-firebase/messaging": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@capacitor/network": "^8.0.0",
    "@date-fns/tz": "^1.4.1",
    "@jsverse/transloco": "^8.3.0",
    "@ngrx/component": "^21.0.0",
    "@ngrx/component-store": "^21.0.0",
    "@ngrx/effects": "^21.0.0",
    "@ngrx/entity": "^21.0.0",
    "@ngrx/operators": "^21.0.0",
    "@ngrx/store": "^21.0.0",
    "@ngrx/store-devtools": "^21.0.0",
    "angular-gridster2": "^21.0.1",
    "apollo-angular": "^14.0.0",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "chartjs-chart-treemap": "^3.1.0",
    "d3": "^7.9.0",
    "d3-color": "^3.1.0",
    "date-fns": "^4.1.0",
    "firebase": "12.13.0",
    "gql-query-builder": "^3.8.0",
    "graphql": "^16.14.0",
    "json-patch": "^0.7.0",
    "lightweight-charts": "^5.2.0",
    "ng-zorro-antd": "^21.0.0",
    "ng2-charts": "^10.0.0",
    "ngx-device-detector": "^11.0.0",
    "ngx-markdown": "^21.0.0",
    "pixi.js": "^8.19.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.0.0",
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@ant-design/icons-angular": "^21.0.0",
    "@capacitor/android": "^8.0.0",
    "@capacitor/assets": "^3.0.0",
    "@capacitor/cli": "^8.0.0",
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/add": "^7.0.0",
    "@graphql-codegen/cli": "^7.0.0",
    "@graphql-codegen/typescript": "^6.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/d3": "^7.4.3",
    "@types/d3-axis": "^3.0.6",
    "@types/d3-color": "^3.1.3",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-scale-chromatic": "^3.1.0",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/json-patch": "^0.0.33",
    "@types/node": "^25.9.0",
    "@vitest/coverage-v8": "^4.1.6",
    "angular-eslint": "^21.4.0",
    "browserslist": "^4.28.2",
    "eslint": "^10.3.0",
    "eslint-formatter-unix": "^9.0.1",
    "glob": "^13.0.6",
    "graphql-codegen-typescript-validation-schema": "^0.19.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "less": "^4.6.4",
    "ng-packagr": "^21.2.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.6"
  },
  "browserslist": [
    "defaults"
  ]
}
