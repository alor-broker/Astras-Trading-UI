{
  "name": "astras-web-terminal",
  "version": "8.0.0",
  "scripts": {
    "ng": "ng",
    "build": "ng build",
    "lint": "ng lint --max-warnings 0",
    "codegen-hyperion": "graphql-codegen --config hyperion-codegen.ts",
    "codegen-news": "graphql-codegen --config news-codegen.ts",

    "start:desktop": "ng serve --project desktop-terminal",
    "start:mobile": "ng serve --project mobile-terminal",
    "start:admin": "ng serve --project admin-terminal --port 4220",

    "build:desktop": "ng build --project desktop-terminal",
    "build:mobile": "ng build --project mobile-terminal",
    "build:admin": "ng build --project admin-terminal",
    "build:all": "pnpm build:desktop && pnpm build:mobile && pnpm build:admin"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "dependencies": {
    "@angular/animations": "^21.2.13",
    "@angular/cdk": "^21.2.11",
    "@angular/common": "^21.2.13",
    "@angular/compiler": "^21.2.13",
    "@angular/core": "^21.2.13",
    "@angular/forms": "^21.2.13",
    "@angular/platform-browser": "^21.2.13",
    "@angular/router": "^21.2.13",
    "@angular/service-worker": "^21.2.13",
    "@apollo/client": "^4.1.9",
    "@capacitor-firebase/messaging": "^8.0.1",
    "@capacitor/core": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@capacitor/network": "^8.0.0",
    "@date-fns/tz": "^1.4.1",
    "@jsverse/transloco": "^8.3.0",
    "@ngrx/component": "^21.1.0",
    "@ngrx/component-store": "^21.1.0",
    "@ngrx/effects": "^21.1.0",
    "@ngrx/entity": "^21.1.0",
    "@ngrx/operators": "^21.1.0",
    "@ngrx/store": "^21.1.0",
    "@ngrx/store-devtools": "^21.1.0",
    "angular-gridster2": "^21.0.1",
    "apollo-angular": "^13.0.0",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "chartjs-chart-treemap": "^3.1.0",
    "d3": "^7.9.0",
    "d3-color": "^3.1.0",
    "date-fns": "^4.1.0",
    "firebase": "12.12.1",
    "gql-query-builder": "^3.8.0",
    "graphql": "^16.14.0",
    "json-patch": "^0.7.0",
    "lightweight-charts": "^5.2.0",
    "ng-zorro-antd": "^21.2.2",
    "ng2-charts": "^10.0.0",
    "ngx-device-detector": "^11.0.0",
    "ngx-markdown": "^21.3.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.4.0",
    "@angular/build": "^21.2.11",
    "@angular/cli": "^21.2.11",
    "@angular/compiler-cli": "^21.2.13",
    "@ant-design/icons-angular": "^21.0.0",
    "@capacitor/android": "^8.0.0",
    "@capacitor/assets": "^3.0.0",
    "@capacitor/cli": "^8.0.0",
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/add": "^6.0.1",
    "@graphql-codegen/cli": "^6.3.1",
    "@graphql-codegen/typescript": "^5.0.10",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/d3": "^7.4.3",
    "@types/d3-axis": "^3.0.6",
    "@types/d3-color": "^3.1.3",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-scale-chromatic": "^3.1.0",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/json-patch": "^0.0.33",
    "@types/node": "^25.8.0",
    "angular-eslint": "^21.4.0",
    "browserslist": "^4.28.2",
    "eslint": "^10.3.0",
    "graphql-codegen-typescript-validation-schema": "^0.18.1",
    "jsdom": "^27.4.0",
    "less": "^4.6.4",
    "ng-packagr": "^21.2.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6",
    "glob": "^13.0.6"
  },
  "browserslist": [
    "defaults"
  ]
}
